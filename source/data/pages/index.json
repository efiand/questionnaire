{
  "pageTitle": "Анкета",
  "blocks": [
    {
      "name": "form",
      "params": {
        "method": "post",
        "action": "https://echo.htmlacademy.ru",
        "groups": [
          {
            "name": "form-group",
            "params": {
              "mix": "form-group--fields form-group--nearest",
              "heading": "Паспортные данные",
              "headingMix": "visually-hidden",
              "fields": [
                {
                  "name": "field",
                  "params": {
                    "label": "Полное ФИО",
                    "type": "text ",
                    "name": "name",
                    "value": "Ефимов Андрей Николаевич",
                    "placeholder": "Иванов Иван Иванович",
                    "required": true
                  }
                },
                {
                  "name": "field",
                  "params": {
                    "label": "Год рождения",
                    "type": "number",
                    "name": "birthdate",
                    "value": "1984",
                    "placeholder": "1990"
                  }
                },
                {
                  "name": "field",
                  "params": {
                    "label": "Место жительства",
                    "type": "text",
                    "name": "location",
                    "value": "г. Санкт-Петербург, Россия",
                    "placeholder": "г. Иваново, Россия",
                    "required": true
                  }
                }
              ]
            }
          },
          {
            "name": "form-group",
            "params": {
              "heading": "Контакты",
              "headingMix": "visually-hidden",
              "fields": [
                {
                  "name": "field",
                  "params": {
                    "label": "Скайп",
                    "type": "text",
                    "name": "skype",
                    "value": "efiand",
                    "placeholder": "ivanov"
                  }
                },
                {
                  "name": "field",
                  "params": {
                    "label": "Почта",
                    "type": "email",
                    "name": "mail",
                    "value": "efiand@ya.ru",
                    "placeholder": "ivanov@gmail.com",
                    "required": true
                  }
                }
              ]
            }
          },
          {
            "name": "form-group",
            "params": {
              "heading": "Расскажите о себе чекбоксами",
              "description": "Отметьте чекбоксами пункты, которые соответствуют вашим скиллам. Кстати, отсутствие опыта не означает, что у вас меньше шансов стать одним из наших товарищей. Это означает, что вы будете получать те задачи, с которыми гарантировано будете справляться.",
              "checkers": [
                {
                  "name": "checker",
                  "params": {
                    "label": "БЭМ/OOCSS",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "bem",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Pug (Jade)",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "pug"
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Stylus/LESS/SASS",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "css-preprocessor",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Работаю с SVG",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "svg",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Верстаю семантично",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "semantic",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Accessibility (A11Y)",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "a11y",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "ES2015/ES2016",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "es6",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Gulp/GRUNT",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "task-runners",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Webpack",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "webpack",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Дружу с WebGL",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "webgl",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "jQuery",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "jquery",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Знаю/изучаю Angular",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "angular"
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Знаю/изучаю React",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "react"
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Знаю/изучаю Node.js",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "node",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Использую Git",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "git",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "С глазомером всё ок",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "eye-estimation",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Читаю <a href=\"https://blog.csssr.ru\">blog.csssr.ru</a>",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "blog",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Я ленивый(-ая)",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "lasy"
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "У меня хороший английский",
                    "type": "checkbox",
                    "name": "properties",
                    "value": "english"
                  }
                }
              ]
            }
          },
          {
            "name": "form-group",
            "params": {
              "heading": "Уровень владения JavaScript",
              "mix": "form-group--ranger",
              "ranger": {
                "name": "ranger",
                "params": {
                  "name": "js",
                  "label": "Шкала уровня владения в процентах",
                  "value": 55,
                  "items": [
                    {
                      "label": "Не владею",
                      "width": "20%"
                    },
                    {
                      "label": "Использую готовые решения",
                      "width": "30%"
                    },
                    {
                      "label": "Использую готовые решения и умею их переделывать",
                      "width": "30%"
                    },
                    {
                      "label": "Пишу сложный JS с нуля",
                      "width": "20%"
                    }
                  ]
                }
              }
            }
          },
          {
            "name": "form-group",
            "params": {
              "heading": "Расскажите о себе словами",
              "mix": "form-group--message",
              "description": "Напишите пару предложений, чем вас привлекла наша вакансия и чего вы ожидаете от работы в CSSSR. Кстати, будет здорово, если при нехватке места для текста строки будут добавляться автоматически.",
              "fields": [
                {
                  "name": "field",
                  "params": {
                    "label": "Текст сообщения",
                    "labelMix": "visually-hidden",
                    "type": "textarea",
                    "name": "message",
                    "value": "Вакансия привлекла хорошими практиками (семантика, a11y, БЭМ), организованностью, стремлением к качеству. Ожидаю перспектив профессионального роста.\nP.S. Опыт работы с Vue.js (Nuxt.js).",
                    "placeholder": "Ну-ууу-уу...\nЭэээ..."
                  }
                }
              ]
            }
          },
          {
            "name": "form-group",
            "params": {
              "heading": "Какие у вас планы на будущее?",
              "mix": "form-group--radio",
              "description": "Этот ответ ни на что не повлияет. Не беда, если в будущем ваши планы поменяются.",
              "checkers": [
                {
                  "name": "checker",
                  "params": {
                    "label": "Верстать",
                    "type": "radio",
                    "name": "plans",
                    "value": "layout"
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Прокачиваться в JS",
                    "type": "radio",
                    "name": "plans",
                    "value": "js",
                    "checked": true
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Менеджерство",
                    "type": "radio",
                    "name": "plans",
                    "value": "management"
                  }
                },
                {
                  "name": "checker",
                  "params": {
                    "label": "Другое",
                    "type": "radio",
                    "name": "plans",
                    "value": "other"
                  }
                }
              ]
            }
          },
          {
            "name": "form-group",
            "params": {
              "heading": "Дополнительно",
              "headingMix": "visually-hidden",
              "fields": [
                {
                  "name": "field",
                  "params": {
                    "label": "Дата заполнения",
                    "inputMix": "field__input--date",
                    "type": "text",
                    "name": "date",
                    "value": "24.05.2019",
                    "placeholder": "01.01.2016"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
